pipeline {
    agent {
        node {
            label 'agent-1'
        }
    }
    
    options {
        timeout(time: 1, unit:'HOURS')
        disableConcurrentBuilds()
        ansiColor('xterm')
    }
    stages {
        stage('terraform init') {
            steps {
                sh """
                    cd 01-vpc-creation
                    terraform init -reconfigure
                    """
            }
        }
        stage('terraform plan') {
            steps {
                sh """
                    cd 01-vpc-creation
                    terraform plan
                    """
            }
        }
        stage('Apply') {
            input {
                message "Should we continue Infra Creation?"
                ok "Yes, we should"
            }
            steps {
                sh """
                    cd 01-vpc-creation
                    terraform apply -auto-approve
                    """
            }
        }
        stage('Destory') {
            input {
                message "Should we continue Infra Destroy?"
                ok "Yes, we should"
            }
            steps {
                sh """
                    cd 01-vpc-creation
                    terraform destroy -auto-approve
                    """
            }
        }
        
    }
    // post build
    post {
        always{
            echo 'We Will always Win again!'
        }
        failure {
            echo 'failure occured, inform the concerned teams over slack'
        }
        success {
            echo 'Confragulations on success build'
        }
    }
}